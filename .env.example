# MapSumbong Admin Dashboard — Environment Variables
# Copy this file to .env and fill in your credentials

# Supabase (connect to your Flutter app's backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these, the dashboard runs on demo/seeded data (still fully functional for hackathon demo)
